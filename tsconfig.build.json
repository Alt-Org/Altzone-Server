{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "multer"],
    "noEmitOnError": true,
    "declaration": false,
    "sourceMap": false,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**"
  ],
  "include": ["src/**/*"]
}
